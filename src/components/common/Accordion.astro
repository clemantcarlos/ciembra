---
import RightArrow from '../icons/RightArrow.astro'

interface Props{
  title:string;
}

const { title } = Astro.props
---
<article class="w-full text-primary">
  <header class="header">
    <h3 class="text-2xl font-semibold">{title}</h3>
    <RightArrow class="arrow"/>
  </header>
  <main>

  </main>
</article>

<script>
  const headers = document.querySelectorAll('.header');
  const arrows = document.querySelectorAll('.arrow')

  const clickHandler = ( e:any ) => {
    console.log(e.target)

    arrows.forEach((arrow)=>{
      arrow.classList.toggle('active')
    })
    // const btn = e.target
    // btn.classList.toggle('active-button')
  }
  headers.forEach((button) => {
    button.addEventListener('click', clickHandler)
  }, true)
</script>

<style>
  .header{
    @apply w-full flex gap-x-4 items-center hover:cursor-pointer
  }
  .arrow{
    @apply size-10 transition-all
  }
  .active{
    @apply rotate-90
  }
</style>