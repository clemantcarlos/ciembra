---
interface Props{
  badgeLabel:string;
  title:string;
  className?:string;
}
const { badgeLabel, title, className } = Astro.props
---
<header class={"w-full flex " + className}>
  <span class="text-sm bg-primary text-secondary rounded-full px-3 py-1">
    {badgeLabel}
  </span>
  <h2 class="text-4xl text-pretty text-primary font-bold">
    {title}
  </h2>
</header>