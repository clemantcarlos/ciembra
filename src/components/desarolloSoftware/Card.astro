---
interface Props{
  title:string;
  text:string;
}

const {title, text} = Astro.props

---
<article class="w-full flex gap-x-4 text-primary items-start">
  <figure class="w-fit">
    <slot/>
  </figure>
  <div class="w-3/4 flex flex-col">
    <h3 class="text-2xl font-bold">{title}</h3>
    <p class="text-pretty">{text}</p>
  </div>
</article>